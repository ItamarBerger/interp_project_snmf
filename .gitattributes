# Ignore any json, pkl, pt files in experiments/artifacts and track them with LFS
experiments/artifacts/**/*.json filter=lfs diff=lfs merge=lfs -text
experiments/artifacts/**/*.pkl filter=lfs diff=lfs merge=lfs -text
experiments/artifacts/**/*.pt filter=lfs diff=lfs merge=lfs -text

# graphml files for concept trees - can all be easily created, no need to save in repo
experiments/artifacts/concept_trees/*.graphml
experiments/artifacts/gpt2-small/**/*.json filter=lfs diff=lfs merge=lfs -text
experiments/artifacts/gpt2-small/**/*.pkl filter=lfs diff=lfs merge=lfs -text
experiments/artifacts/gpt2-small/**/*.pt filter=lfs diff=lfs merge=lfs -text
